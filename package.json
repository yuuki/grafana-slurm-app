{
  "name": "yuuki-slurm-app",
  "version": "0.1.0",
  "description": "Grafana app plugin for monitoring Slurm jobs with per-job GPU/CPU/network metrics",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --ci",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache --ext .js,.jsx,.ts,.tsx ./src",
    "lint:fix": "eslint --cache --fix --ext .js,.jsx,.ts,.tsx ./src",
    "server": "docker compose up --build",
    "e2e": "npx playwright test",
    "e2e:setup": "docker compose -f docker-compose.yaml -f docker-compose.e2e.yaml up -d --wait"
  },
  "author": "yuuki",
  "license": "Apache-2.0",
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@swc/core": "^1.10.0",
    "@swc/jest": "^0.2.37",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "fork-ts-checker-webpack-plugin": "^9.0.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.7.2",
    "webpack": "^5.97.0",
    "webpack-cli": "^6.0.1",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@grafana/data": "^12.0.0",
    "@grafana/runtime": "^12.0.0",
    "@grafana/scenes": "^6.0.0",
    "@grafana/ui": "^12.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.28.0",
    "tslib": "^2.8.1"
  },
  "packageManager": "npm@11.0.0",
  "engines": {
    "node": ">=22"
  }
}
