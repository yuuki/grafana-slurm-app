{
  "name": "yuuki-slurm-app",
  "version": "0.3.2",
  "description": "Grafana app plugin for monitoring Slurm jobs with per-job GPU/CPU/network metrics",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "deploy:full:ssh": "bash ./scripts/deploy-full-ssh.sh",
    "deploy:grafana:ssh": "bash ./scripts/deploy-plugin-ssh.sh",
    "install:grafana": "bash ./scripts/install-plugin.sh",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --ci",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache ./src",
    "lint:fix": "eslint --cache --fix ./src",
    "server": "docker compose up --build",
    "e2e": "npx playwright test",
    "e2e:setup": "docker compose -f docker-compose.yaml -f docker-compose.e2e.yaml up -d --wait"
  },
  "author": "yuuki",
  "license": "Apache-2.0",
  "devDependencies": {
    "@grafana/eslint-config": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@grafana/data": "^12.4.0",
    "@grafana/runtime": "^12.4.0",
    "@grafana/scenes": "^6.57.2",
    "@grafana/ui": "^12.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "tslib": "^2.8.1"
  },
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24 <25"
  }
}
